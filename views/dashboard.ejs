<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Dashboard</title>

<link rel="stylesheet" href="/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/all.css">
<link rel="stylesheet" href="/css/style.css">

</head>

<body class="dashboard-page">

<div class="container mt-5">

<div class="card shadow">

<div class="card-header bg-dark text-white">
<h3>Dashboard</h3>
</div>

<div class="card-body">

<h4>Welcome <%= user.email %></h4>

<hr>

<!-- OWNER -->
<% if(user.role === "owner"){ %>

<h5 class="text-danger">You are Owner</h5>

<a href="/members" class="btn btn-warning">
Manage Employees
</a>

<a href="/manage" class="btn btn-info">
Manage Products
</a>

<!-- EMPLOYEE -->
<% } else if(user.role === "employee"){ %>

<h5 class="text-primary">You are Employee</h5>

<a href="/manage" class="btn btn-info">
Manage Products
</a>

<a href="/sales/new" class="btn btn-success">
Sell Product
</a>

<!-- CUSTOMER -->
<% } else if(user.role === "customer"){ %>

<h5 class="text-success">You are Customer</h5>

<a href="/orders" class="btn btn-primary">
My Orders
</a>

<a href="/" class="btn btn-info">
Shop Products
</a>

<% } %>

<hr>

<div class="mt-3">

<a href="/" class="btn btn-secondary">
Home
</a>

<a href="/logout" class="btn btn-danger">
Logout
</a>

</div>

</div>

</div>

</div>

</body>
</html>